// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String     @id @default(uuid())
  name           String
  email          String     @unique
  hashedPassword String
  role           String     @default("ADMIN") // e.g. SUPERADMIN, ADMIN
  auditLogs      AuditLog[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  programs  Program[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Program {
  id                 String        @id @default(uuid())
  title              String
  slug               String        @unique
  description        String
  syllabus           String        // Syllabus outline (markdown or structured text)
  location           String        // e.g. "STC Lab, TPM Bukit Jalil"
  price              String?       // e.g. "Free" or "RM 1,500"
  duration           String?       // e.g. "3 Days", "5 Days"
  dates              String?       // e.g. "2026-07-15 to 2026-07-18"
  microsoftFormUrl   String        // Enrollment Form redirect URL
  imageUrl           String?       // Cloudflare R2 public URL
  imageUrls          String[]      @default([]) // Cloudflare R2 public URLs
  categoryId         String
  category           Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g. "CREATE_PROGRAM", "IMPORT_ENROLLMENTS"
  details   String   // Details description
  adminId   String?
  admin     User?    @relation(fields: [adminId], references: [id], onDelete: SetNull)
  ipAddress String?
  createdAt DateTime @default(now())
}

model Stat {
  id        String   @id @default(uuid())
  number    String   // e.g. "150,000+"
  label     String   // e.g. "Students & Professionals"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Partner {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String   // Cloudflare R2 public URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhyChooseUsCard {
  id          String   @id @default(uuid())
  title       String
  description String
  imageUrl    String?  // Cloudflare R2 public URL or placeholder
  colspan     Int      @default(1) // 1 or 2 for Bento Grid
  order       Int      @default(0) // Sorting order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(uuid())
  quote     String
  name      String
  role      String
  company   String
  order     Int      @default(0) // Sorting order
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model AboutSettings {
  id        String   @id @default(uuid())
  mission   String
  vision    String
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(uuid())
  name      String
  role      String
  imageUrl  String?  // Cloudflare R2 / S3 public upload link
  initials  String
  order     Int      @default(0) // For custom drag-and-drop ordering
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

model NewsArticle {
  id            String   @id @default(uuid())
  title         String
  category      String   // e.g. "Facilities Update", "Administration"
  date          String   // Display date e.g. "20 June 2026"
  description   String   // Short description
  content       String   @default("") // Detailed article body content (Markdown)
  imageUrl      String?  // Cloudflare R2 public URL
  isHighlighted Boolean  @default(false) // If true, shown in hero carousel
  order         Int      @default(0) // Sort order
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isHighlighted])
  @@index([order])
}

model Facility {
  id        String   @id @default(uuid())
  index     String
  title     String
  subtitle  String
  imageUrl  String?
  desc      String
  specs     String[] @default([])
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}


