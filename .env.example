# Database Configuration
# Prisma supports PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/mydb?schema=public"

# Admin Authentication Settings
# Email and password used to access the admin dashboard
ADMIN_EMAIL="admin@mimos.my"
ADMIN_PASSWORD="mimos2026_secure_password_change_me"

# Admin Session Cookie Security Secret
# Cryptographic secret used to sign admin session cookies to prevent tampering.
# Generating a secure 64-character hex string is highly recommended.
ADMIN_SESSION_SECRET="your_secure_64_character_hex_session_secret"

# Cloudflare R2 / S3-compatible Object Storage Configuration
# Used for uploading program posters, team member photos, and news images.
CLOUDFLARE_R2_ACCOUNT_ID="your_cloudflare_r2_account_id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your_cloudflare_r2_access_key_id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_cloudflare_r2_secret_access_key"
CLOUDFLARE_R2_BUCKET_NAME="mimos-website"
CLOUDFLARE_R2_PUBLIC_URL="https://pub-yourbucketpublicurl.r2.dev"
